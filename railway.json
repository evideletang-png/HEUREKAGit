{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile",
    "watchPatterns": [
      "/apps/api/**",
      "/apps/web/**",
      "/packages/**",
      "/Dockerfile",
      "/railway.json",
      "/package.json",
      "/pnpm-lock.yaml",
      "/pnpm-workspace.yaml",
      "/.npmrc"
    ]
  },
  "deploy": {
    "startCommand": "node apps/api/dist/index.cjs",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE"
  }
}
