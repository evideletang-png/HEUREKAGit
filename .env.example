# Copy this file to .env and fill in real values.
# .env is git-ignored — never commit secrets.
#
# Quick local dev setup:
#   cp .env.example .env          # fill in POSTGRES_PASSWORD and JWT_SECRET
#   docker compose up db -d       # start Postgres only
#   pnpm install                  # install all workspace deps
#   pnpm --filter @workspace/api-server dev   # start API (port 8080)
#   pnpm --filter @workspace/heureka dev      # start frontend (port 5173)

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080
NODE_ENV=development

# ── Auth ────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace_with_a_strong_password
POSTGRES_DB=heureka
DATABASE_URL=postgresql://postgres:replace_with_a_strong_password@localhost:5432/heureka

# ── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── CORS (production only) ───────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave unset to allow all (dev default).
# ALLOWED_ORIGIN=https://your-app.railway.app
